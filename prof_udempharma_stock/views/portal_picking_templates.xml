<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <template id="portal_my_home_pickings"
          name="Portal My Home : Pickings"
          inherit_id="portal.portal_my_home"
          priority="60"
          customize_show="True">
  <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
    <a class="o_portal_docs_link d-flex align-items-center gap-2" href="/my/pickings">
      <img t-att-src="'/stock/static/img/replenishment.svg'"
           alt="Movimenti"
           style="width:24px;height:24px;"/>
      <span>Movimenti</span>

      <!-- Count (se vuoi mantenerlo) -->
      <t t-if="picking_count">
        <span class="badge rounded-pill bg-secondary ms-auto">
          <t t-esc="picking_count"/>
        </span>
      </t>
    </a>
    <div class="text-muted small ms-4">Movimentazione prodotti</div>
  </xpath>
</template>
  <template id="portal_breadcrumbs_pickings" name="Portal layout : Pickings breadcrumbs" inherit_id="portal.portal_breadcrumbs" priority="60">
    <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
      <li t-attf-class="breadcrumb-item #{'active' if page_name == 'picking' and not picking else ''}">
        <a t-if="page_name == 'picking' and not picking" t-attf-href="/my/pickings?{{ keep_query() }}">Ordini di consegna</a>
        <t t-else="">Ordini di consegna</t>
      </li>
      <li t-if="picking" class="breadcrumb-item active"><t t-esc="picking.name"/></li>
    </xpath>
  </template>

  <template id="portal_my_pickings" name="My Pickings">
    <t t-call="portal.portal_layout">
      <t t-set="breadcrumbs_searchbar" t-value="True"/>
      <t t-call="portal.portal_searchbar"><t t-set="title">Ordini di consegna</t></t>

      <t t-if="not pickings"><p>non ci sono ordini di consegna</p></t>

      <t t-if="pickings" t-call="portal.portal_table">
        <thead>
          <tr><th>Reference</th><th class="text-left">Date prevista</th><th class="text-left">Operazione</th><th class="text-left">Stato</th></tr>
        </thead>
        <tbody>
          <t t-foreach="pickings" t-as="p">
            <tr>
              <td>
                <!--
                <a t-att-href="p.get_portal_url()"><t t-esc="p.name"/></a>
                -->
              <a t-attf-href="/my/pickings/{{ p.id }}"><t t-esc="p.name"/></a>
              </td>
              <td class="text-left"><span t-field="p.scheduled_date"/></td>
              <td class="text-left"><span t-field="p.picking_type_id"/></td>
              <td class="text-left"><span t-field="p.state"/></td>
            </tr>
          </t>
        </tbody>
      </t>

      <t t-if="pager">
              <t t-call="website.pager"/>
     </t>
    </t>
  </template>

  <template id="portal_picking_page" name="Picking Portal Page" inherit_id="portal.portal_sidebar" primary="True">
    <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
      <div class="row mt16 o_portal_sale_sidebar">
        <t t-call="portal.portal_record_sidebar">
          <t t-set="classes" t-value="'col-lg-auto d-print-none'"/>
          <t t-set="title"><h2 class="mb-0">Delivery <t t-esc="picking.name"/> [ <span t-field="picking.state"/> ]</h2></t>
          <t t-set="entries">
            <ul class="list-group list-group-flush flex-wrap flex-row flex-lg-column">
              <li class="list-group-item flex-grow-1">
                <div class="o_download_pdf btn-toolbar flex-sm-nowrap">
                  <div class="btn-group flex-grow-1 mr-1 mb-1">
                    <a class="btn btn-secondary btn-block o_download_btn" t-att-href="picking.get_portal_url(report_type='pdf', download=True)" title="Download">
                      <i class="fa fa-download"/> Download PDF
                    </a>
                  </div>
                </div>
              </li>
              <li class="navspy list-group-item pl-0 flex-grow-1" t-ignore="true" role="complementary"><ul class="nav flex-column bs-sidenav"/></li>
            </ul>
          </t>
        </t>

        <div class="col-12 col-lg justify-content-end">
          <div class="card"><div class="card-body">
            <div class="row">
              <div class="col-lg-6">
                <table width="100%">
                  <tr><td width="35%" style="padding:3px"><b>Cliente</b></td><td width="5%" style="padding:3px">:</td><td width="60%" style="padding:3px"><span t-field="picking.partner_id"/></td></tr>
                  <tr><td style="padding:3px"><b>Date prevista</b></td><td style="padding:3px">:</td><td style="padding:3px"><span t-field="picking.scheduled_date"/></td></tr>
                  <tr><td style="padding:3px"><b>Source Location</b></td><td style="padding:3px">:</td><td style="padding:3px"><span t-field="picking.location_id"/></td></tr>
                  <tr><td style="padding:3px"><b>Destination</b></td><td style="padding:3px">:</td><td style="padding:3px"><span t-field="picking.location_dest_id"/></td></tr>
                </table>
              </div>
              <div class="col-lg-6">
                <table width="100%">
                  <tr><td width="35%" style="padding:3px"><b>Operazione</b></td><td width="5%" style="padding:3px">:</td><td width="60%" style="padding:3px"><span t-field="picking.picking_type_id"/></td></tr>
                  <tr><td style="padding:3px"><b>Origin</b></td><td style="padding:3px">:</td><td style="padding:3px"><span t-field="picking.origin"/></td></tr>
                  <tr><td style="padding:3px"><b>Company</b></td><td style="padding:3px">:</td><td style="padding:3px"><span t-field="picking.company_id"/></td></tr>
                </table>
              </div>
            </div>

            <div class="mt-3">
              <h5 class="mb-2">Movimenti</h5>
              <table class="table table-sm">
                <thead>
                  <tr>
                  <th>Productto</th>
                  <th class="text-left">Richiesti</th>
                  <th class="text-left">Fatto</th>
                  <th class="text-left">UoM</th>
                  <th class="text-left">Disponibilità</th>
                </tr>
                </thead>
                <tbody>
                  <t t-foreach="picking.move_ids_without_package" t-as="m">
                    <tr>
                      <td><span t-field="m.product_id"/></td>
                      <td class="text-left"><span t-field="m.product_uom_qty"/></td>
                      <td class="text-left">

                        <span t-esc="sum(m.move_line_ids.mapped('qty_done'))"/>
                      </td>
                      <td class="text-left">

                        <span t-field="m.product_uom"/>
                      </td>
                      <td class="text-left">
                        <t t-set="a" t-value="availability.get(m.product_id.id)"/>
                        <t t-if="a">
                          <t t-esc="a['qty_available']"/> <t t-esc="a['uom_name']"/>
                        </t>
                        <t t-else="">-</t>
                      </td>
                    </tr>
                  </t>
                </tbody>
              </table>
            </div>

            <div class="mt-3">
  <h5 class="mb-2">Dettaglio Movimenti</h5>
  <t t-if="picking.move_line_ids">
    <table class="table table-sm">
      <thead>
        <tr>
          <th>Product</th>
          <th class="text-left">Lotto</th>
          <th class="text-left">Da</th>
          <th class="text-left">A</th>
          <th class="text-left">Fatto</th>
          <th class="text-left">UM</th>
        </tr>
      </thead>
      <tbody>
        <t t-foreach="picking.move_line_ids" t-as="ml">
          <tr>
            <td><span t-field="ml.product_id"/></td>
            <td class="text-left"><t t-if="ml.lot_id"><span t-field="ml.lot_id"/></t><t t-else="">-</t></td>
            <td class="text-left"><span t-field="ml.location_id"/></td>
            <td class="text-left"><span t-field="ml.location_dest_id"/></td>
            <td class="text-left"><span t-field="ml.qty_done"/></td>
            <td class="text-left"><span t-field="ml.product_uom_id"/></td>
          </tr>
        </t>
      </tbody>
    </table>
  </t>
  <t t-else="">
    <p class="mb-0">No movementi.</p>
  </t>
</div>

          </div></div>

          <div class="mt-4">
            <h2>Communication</h2>
            <t t-call="portal.message_thread"><t t-set="object" t-value="picking"/></t>
          </div>
        </div>
      </div>
    </xpath>
  </template>

<template id="portal_my_home_products"
          name="Prodotti"
          inherit_id="portal.portal_my_home"
          priority="65"
          customize_show="True">
  <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
    <a class="o_portal_docs_link d-flex align-items-center gap-2" href="/my/products">
      <img t-att-src="'/stock/static/img/replenishment.svg'"
           alt="Prodotti"
           style="width:24px;height:24px;"/>
      <span>Prodotti</span>
      <small class="text-muted ms-2">I tuoi Prodotti</small>
    </a>
  </xpath>
</template>


<template id="portal_my_products" name="My Products (from Pickings)">
  <t t-call="portal.portal_layout">
    <t t-set="breadcrumbs_searchbar" t-value="True"/>
    <t t-call="portal.portal_searchbar">
      <t t-set="title">Prodotti</t>
    </t>

    <t t-if="not product_rows">
      <p>Nessun prodotto trovato </p>
    </t>

    <t t-if="product_rows" t-call="portal.portal_table">
      <thead>
        <tr>
          <th>Codice</th>
          <th class="text-left">Nome</th>
          <th class="text-left">Disponibilità</th>
          <th class="text-left">UoM</th>
          <th class="text-left">Richiesto (pickings)</th>
          <th class="text-left">Fatto (pickings)</th>
        </tr>
      </thead>
      <tbody>
        <t t-foreach="product_rows" t-as="r">
          <tr>
            <td><t t-esc="r['code']"/></td>
            <td class="text-left"><t t-esc="r['name']"/></td>
            <td class="text-left"><t t-esc="r['qty_available']"/></td>
            <td class="text-left"><t t-esc="r['uom']"/></td>
            <td class="text-left"><t t-esc="r['qty_demand']"/></td>
            <td class="text-left"><t t-esc="r['qty_done']"/></td>
          </tr>
        </t>
      </tbody>
    </t>

    <t t-if="pager">
      <t t-call="website.pager"/>
    </t>
  </t>
</template>


</odoo>
